{
  "name": "pascal.com.svelte",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vp dev",
    "build": "svelte-kit sync && vp build -l error",
    "preview": "vp preview",
    "test": "npm run test:integration && npm run test:unit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "vp fmt --check . && vp lint .",
    "format": "vp fmt .",
    "test:integration": "playwright test",
    "test:unit": "vp test run",
    "test:unit:watch": "vp test",
    "test:headed": "npx playwright test --project safari --headed --fully-parallel --reporter list",
    "test:production": "PRODUCTION=true npm run test:headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@poppanator/sveltekit-svg": "^7.0.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.63.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/leaflet": "^1.9.6",
    "@types/lodash": "^4.17.5",
    "@types/node": "^25.9.2",
    "@types/pretty": "^2.0.1",
    "@voidzero-dev/vite-plus-core": "^0.1.24",
    "@voidzero-dev/vite-plus-test": "^0.1.24",
    "assert": "^2.1.0",
    "autoprefixer": "^10.4.14",
    "csv-parser": "^3.0.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "less": "^4.1.3",
    "marked": "^7.0.5",
    "mdsvex": "^0.12.7",
    "node-html-markdown": "^1.3.0",
    "open-props": "^1.6.12",
    "postcss-jit-props": "^1.0.14",
    "slugify": "^1.6.6",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-preprocess": "^6.0.5",
    "svelte-preprocess-import-assets": "^1.1.0",
    "tslib": "^2.4.1",
    "turndown": "^7.1.2",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.24"
  },
  "type": "module",
  "dependencies": {
    "@iconslib/svelte": "^0.2.0",
    "@types/uuid": "^9.0.4",
    "focus-trap": "^7.5.2",
    "leaflet": "^1.9.4",
    "lodash": "^4.17.21",
    "pretty": "^2.0.0",
    "remark-attr": "^0.11.1",
    "svelte-icons": "^2.1.0",
    "tone": "^14.7.77",
    "uuid": "^9.0.1"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  },
  "packageManager": "npm@11.13.0"
}
